ALIEXPRESS_TRACKING_ID=
CATEGORY_RESOLUTION_MODE=api

# Google Trends Configuration - BALANCED (más rápido pero con anti-bloqueo)
GOOGLE_TRENDS_MAX_RETRIES=5
GOOGLE_TRENDS_RETRY_DELAY_MS=10000  # 10 segundos para reintentos
GOOGLE_TRENDS_REQUEST_DELAY_MS=5000  # 5 segundos entre requests
GOOGLE_TRENDS_TIMEOUT_MS=90000  # 90 segundos timeout
GOOGLE_TRENDS_CONCURRENCY=1
# GOOGLE_TRENDS_COOKIES=  ← solo pega aquí si tienes NID, SID, APISID, SAPISID, SOCS de trends.google.com
#                           Los cookies _ga/_gid son de Analytics y NO ayudan con el 429

# 🍪 ANTI-429: Pega aquí las cookies de tu navegador para bypassear el rate-limit de Google
# Cómo obtenerlas:
#   1. Abre https://trends.google.com en Chrome/Firefox
#   2. Abre DevTools → pestaña Network → recarga la página
#   3. Clic en la petición a "trends.google.com" → Request Headers → copia el valor de "Cookie"
#   4. Pégalo aquí (remplaza el ejemplo). Las cookies clave son NID, SOCS y __Secure-ENID
# GOOGLE_TRENDS_COOKIES=NID=xxx; SOCS=yyy; __Secure-ENID=zzz

# 🌐 ANTI-429: Proxy HTTP/HTTPS para rotar IP (opcional, descomenta si tienes uno)
# Soporta proxies HTTP, HTTPS y SOCKS5 (socks5://user:pass@host:port)
# GOOGLE_TRENDS_PROXY=http://user:pass@host:port
# También se respetan las variables estándar HTTP_PROXY / HTTPS_PROXY
